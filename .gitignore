# Binary Files
*.pdb
*.idb
*.iobj
*.ipdb
*.vsp
*.psess
Binaries/*
!Binaries/Win64/
Binaries/Win64/*.pdb
Binaries/Win64/*.idb
Binaries/Win64/*.iobj
Binaries/Win64/*.ipdb

# Builds
Build/*

# Whitelist PakBlacklist-<BuildConfiguration>.txt files
!Build/*/
Build/*/**
!Build/*/PakBlacklist*.txt

# Don't ignore icon files in Build
!Build/**/*.ico

# Built data for maps
*_BuiltData.uasset

# Configuration files generated by the Editor
Saved/*

# Compiled source files for the engine to use
Intermediate/*
Plugins/*/Intermediate/*

# Cache, saves, etc
DerivedDataCache/*
Intermediate/*
Platforms/*
Saved/*

# Unreal Engine generated files
DerivedDataCache/
Intermediate/
Saved/
Platforms/
Build/
*.pdb
*.idb
*.iobj
*.ipdb

# Content that might be regenerated
Content/Characters/Mannequins/Meshes/*
!Content/Characters/Mannequins/Meshes/README.md

